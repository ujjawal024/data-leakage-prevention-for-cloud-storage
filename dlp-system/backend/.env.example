# ─────────────────────────────────────────────────────────────
# .env.example — Safe template for environment configuration.
# Copy this file to .env and fill in your own values.
# NEVER commit your actual .env file to source control.
# ─────────────────────────────────────────────────────────────

# Storage backend: local | aws | gcp | azure
CLOUD_PROVIDER=local

# Secret key for JWT token signing — use a long random string in production
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-secret

# Database connection URL
# For local Docker development (PostgreSQL via docker-compose):
DATABASE_URL=postgresql://dlp_user:dlp_password@db:5432/dlp_db
# For local SQLite development (without Docker):
# DATABASE_URL=sqlite:///./dlp.db

# ─────────────────────────────────────────────────────────────
# AWS S3 (only needed when CLOUD_PROVIDER=aws)
# ─────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_BUCKET_NAME=your-dlp-bucket-name

# ─────────────────────────────────────────────────────────────
# Google Cloud Storage (only needed when CLOUD_PROVIDER=gcp)
# ─────────────────────────────────────────────────────────────
GCP_BUCKET_NAME=your-gcp-bucket-name
GOOGLE_APPLICATION_CREDENTIALS=./gcp-credentials.json

# ─────────────────────────────────────────────────────────────
# Azure Blob Storage (only needed when CLOUD_PROVIDER=azure)
# ─────────────────────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=your-azure-connection-string
AZURE_CONTAINER_NAME=your-azure-container-name

# ─────────────────────────────────────────────────────────────
# Local storage (only needed when CLOUD_PROVIDER=local)
# ─────────────────────────────────────────────────────────────
LOCAL_STORAGE_PATH=./local_storage
