CLOUD_PROVIDER=local
SECRET_KEY=dlp-secret-key-change-in-prod
DATABASE_URL=sqlite:///./dlp.db

# AWS S3 (used when CLOUD_PROVIDER=aws)
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret
AWS_REGION=us-east-1
AWS_BUCKET_NAME=dlp-storage

# Google Cloud Storage (used when CLOUD_PROVIDER=gcp)
GCP_BUCKET_NAME=dlp-storage
GOOGLE_APPLICATION_CREDENTIALS=./gcp-credentials.json

# Azure Blob Storage (used when CLOUD_PROVIDER=azure)
AZURE_STORAGE_CONNECTION_STRING=your_connection_string
AZURE_CONTAINER_NAME=dlp-storage

# Local storage path (used when CLOUD_PROVIDER=local)
LOCAL_STORAGE_PATH=./local_storage
